{
    "mcpServers": {
        "maa-mcp": {
            "command": "python",
            "args": [
                "-m",
                "maa_mcp"
            ],
            "disabled": false
        },
        "MiniMax": {
            "command": "uvx",
            "args": [
                "minimax-coding-plan-mcp",
                "-y"
            ],
            "env": {
                "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
                "MINIMAX_API_HOST": "https://api.minimaxi.com"
            },
            "disabled": true
        }
    }
}